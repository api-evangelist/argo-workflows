{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/argo-workflows/refs/heads/main/json-schema/argo-workflows-github-com-argoproj-argo-events-pkg-apis-events-v1alpha1-github-app-creds-schema.json",
  "title": "github.com.argoproj.argo_events.pkg.apis.events.v1alpha1.GithubAppCreds",
